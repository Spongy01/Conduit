{
  "uid": "conduit-business",
  "title": "Conduit: Business",
  "tags": ["conduit"],
  "timezone": "browser",
  "editable": true,
  "refresh": "10s",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "team_id",
        "type": "query",
        "label": "Team",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(requests_total, team_id)", "refId": "team_id_variable" },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Budget utilization per team",
      "description": "Each team's current spend as a percentage of their budget limit.",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "red", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "budget_utilization",
          "legendFormat": "{{team_id}}",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "title": "Requests per team",
      "description": "Traffic broken down by team.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(requests_total[1m])) by (team_id)",
          "legendFormat": "{{team_id}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Successful vs rejected requests per team",
      "description": "Success and non-success request rates, overlaid per team.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(requests_total{status=\"success\"}[1m])) by (team_id)",
          "legendFormat": "{{team_id}} - success"
        },
        {
          "refId": "B",
          "expr": "sum(rate(requests_total{status!=\"success\"}[1m])) by (team_id)",
          "legendFormat": "{{team_id}} - rejected"
        }
      ]
    },
    {
      "id": 4,
      "title": "Top models by usage",
      "description": "Which models are being used most across all teams.",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(requests_total) by (model)",
          "legendFormat": "{{model}}",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "id": 5,
      "title": "Rate limit rejections per team",
      "description": "Total rejections since last restart, one stat per team.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(ratelimit_rejections_total) by (team_id)",
          "legendFormat": "{{team_id}}",
          "instant": true
        }
      ]
    }
  ]
}
