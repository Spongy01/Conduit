{
  "uid": "conduit-operations",
  "title": "Conduit: Operations",
  "tags": ["conduit"],
  "timezone": "browser",
  "editable": true,
  "refresh": "10s",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "team_id",
        "type": "query",
        "label": "Team",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(requests_total, team_id)", "refId": "team_id_variable" },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request rate",
      "description": "Overall traffic (total RPS) and error rate at a glance, broken down by status.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(requests_total[1m]))",
          "legendFormat": "total RPS"
        },
        {
          "refId": "B",
          "expr": "sum(rate(requests_total[1m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error rate %",
      "description": "Share of requests with a non-success status over the last minute.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(requests_total{status!=\"success\"}[1m])) / sum(rate(requests_total[1m])) * 100",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "title": "In-flight requests",
      "description": "Current number of requests being processed right now.",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(inflight_requests)",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Rate limit rejections",
      "description": "Shows which teams are hitting their rate limits.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ratelimit_rejections_total[1m])) by (team_id)",
          "legendFormat": "{{team_id}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Provider request breakdown",
      "description": "Traffic per provider and their success/failure split.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(provider_requests_total[1m])) by (provider, status)",
          "legendFormat": "{{provider}} - {{status}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Fallback events",
      "description": "Shows when and how often fallback routing activates, and between which providers.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(fallback_events_total[1m])) by (from_provider, to_provider)",
          "legendFormat": "{{from_provider}} → {{to_provider}}"
        }
      ]
    }
  ]
}
