# Copy to .env and fill in real values. When running via
# `docker compose -f infra/docker-compose.yaml up`, this file is loaded by
# the gateway service (DATABASE_URL/REDIS_HOST/OTEL_EXPORTER_OTLP_ENDPOINT
# are overridden there to point at the other compose services).
DATABASE_URL=postgresql://conduit:postgres_conduit@localhost:5432/conduit
ADMIN_API_KEY=your-secret-admin-key

# OpenAI, Anthropic, and Ollama default to the `dummy` compose profile's
# services (docker compose -f infra/docker-compose.yaml --profile dummy up),
# so the stack runs end-to-end with no edits. Swap these for real keys/URLs
# to hit live provider APIs instead.
OPENAI_API_KEY=dummy
OPENAI_BASE_URL=http://dummy-openai:8001
ANTHROPIC_API_KEY=dummy
ANTHROPIC_BASE_URL=http://dummy-anthropic:8002
OLLAMA_BASE_URL=http://dummy-ollama:8003

# Gemini has no dummy service; set a real key to use it.
GEMINI_API_KEY=...
